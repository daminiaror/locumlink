# TEMPLATE ONLY — Nest does not load this file. Copy into `backend/.env` (and optional overlays).
# Runtime merge (see `src/config/backend-env-files.ts`): `.env` then `.env.<NODE_ENV>` then `.env.local`.
# Overlays only replace keys they define — values only in `.env` stay available under `NODE_ENV=staging`.
# Never commit real secrets here.

DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5433/l2_db?schema=public"

JWT_SECRET="replace-with-a-long-random-string-at-least-32-characters"
NODE_ENV=staging
PORT=3000

NEXT_PUBLIC_API_URL=http://localhost:3000

# Supabase (same project as frontend — for main-app auth / OTP / JWT sync via POST /api/auth/sync-supabase only)
# SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_URL=
# SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# --- Admin panel: Google OAuth via Nest Passport (separate OAuth client — NOT Supabase) ---
# 1. Google Cloud → APIs & Credentials → OAuth 2.0 Client (Web application)
#    Authorized redirect URIs:
#      http://localhost:3000/api/admin-auth/google/callback
#      (plus your production URL, same path on the Nest host)
# 2. GOOGLE_ADMIN_* below must match that client.
# 3. Seed allowed admin emails in Postgres:
#      ADMIN_SEED_EMAIL="you@gmail.com" ADMIN_SEED_NAME="You" node database/seed-admin.mjs
#
# GOOGLE_ADMIN_CLIENT_ID=
# GOOGLE_ADMIN_CLIENT_SECRET=
# GOOGLE_ADMIN_CALLBACK_URL=http://localhost:3000/api/admin-auth/google/callback
#
# ADMIN_FRONTEND_REDIRECT_URL=http://localhost:3001/admin/dashboard
# ADMIN_JWT_SECRET=            # optional; falls back to JWT_SECRET
# ADMIN_JWT_EXPIRES_IN=7d

