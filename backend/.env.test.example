# Copy to backend/.env.test for local E2E runs.
# Uses a dedicated database (l2_test) — never point at Supabase/dev/production.
#
# Prerequisites (pick one):
#   A) Docker (recommended): docker compose up -d postgres  (host port 5433)
#   B) Local PostgreSQL 18: create database l2_test, set URL below to port 5432
#
# global-setup creates l2_test if missing (Docker) and runs prisma migrate deploy.

NODE_ENV=test

# Docker Postgres — separate DB from dev l2_db
TEST_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/l2_test?schema=public
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/l2_test?schema=public

# Local PG18 alternative (uncomment and set your install password):
# TEST_DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@127.0.0.1:5432/l2_test?schema=public
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@127.0.0.1:5432/l2_test?schema=public

JWT_SECRET=test-jwt-secret-at-least-32-characters-long-for-integration

ZEPTOMAIL_API_KEY=
MAIL_FROM_ADDRESS=noreply@example.test

PLATFORM_TIMEZONE=America/Halifax
