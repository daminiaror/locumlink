# Copy to frontend/.env.local (not committed).

# Same Postgres URL as backend/.env (required for /api/admin/* routes)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/l2_db?schema=public

# Must match backend JWT used to sign ll_admin cookie after /api/admin-auth/login
JWT_SECRET=replace-with-same-value-as-backend-JWT_SECRET

# Nest API (rewrites for admin-auth login, host, locum, etc.)
NEXT_PUBLIC_API_URL=http://localhost:3000

# Optional: exact OAuth callback shown on /admin/login (must match backend + Google Cloud)
# NEXT_PUBLIC_ADMIN_OAUTH_CALLBACK_URL=http://localhost:3002/api/admin-auth/google/callback
