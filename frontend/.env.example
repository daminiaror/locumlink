# Copy to frontend/.env.local (not committed).

# Same Postgres URL as backend/.env (required for /api/admin/* routes)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/l2_db?schema=public

# Must match backend JWT that signs ll_admin (dev API uses backend/.env.staging via NODE_ENV=staging)
JWT_SECRET=copy-from-backend-.env.staging-JWT_SECRET

# Nest API — used by Next.js server rewrites (browser calls same-origin /api/*)
API_INTERNAL_URL=http://127.0.0.1:3000

# Optional public API URL for server-side fetches only (leave unset for same-origin /api proxy)
# NEXT_PUBLIC_API_URL=http://localhost:3000

# Optional: exact OAuth callback shown on /admin/login (must match backend + Google Cloud)
# NEXT_PUBLIC_ADMIN_OAUTH_CALLBACK_URL=http://localhost:3001/api/admin-auth/google/callback
