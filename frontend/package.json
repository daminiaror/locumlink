{
  "name": "frontend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate --schema=../database/prisma/schema.prisma",
    "dev": "node --max-old-space-size=4096 ../node_modules/next/dist/bin/next dev -p 3001",
    "dev:turbo": "node --max-old-space-size=4096 ../node_modules/next/dist/bin/next dev --turbo -p 3001",
    "dev:clean": "node --max-old-space-size=4096 ../node_modules/next/dist/bin/next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "next lint"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@supabase/supabase-js": "^2.101.1",
    "jose": "^6.0.10",
    "pg": "^8.16.3",
    "axios": "^1.15.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.5.9",
    "prisma": "^7.7.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.3"
  }
}
