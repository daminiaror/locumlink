{
  "name": "frontend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate --schema=../database/prisma/schema.prisma",
    "dev": "node --max-old-space-size=1536 ../node_modules/next/dist/bin/next dev -p 3001",
    "dev:vm": "node --max-old-space-size=1024 ../node_modules/next/dist/bin/next dev -p 3001",
    "dev:webpack": "node --max-old-space-size=1024 ../node_modules/next/dist/bin/next dev -p 3001",
    "dev:turbo": "node --max-old-space-size=1024 ../node_modules/next/dist/bin/next dev --turbo -p 3001",
    "dev:clean": "node --max-old-space-size=1024 ../node_modules/next/dist/bin/next dev -p 3001",
    "dev:3002": "node --max-old-space-size=1024 ../node_modules/next/dist/bin/next dev --turbo -p 3002",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "eslint src"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.19.0",
    "@next/third-parties": "^16.2.6",
    "@prisma/adapter-pg": "^6.0.0",
    "@prisma/client": "^6.0.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.101.1",
    "axios": "^1.15.0",
    "driver.js": "^1.4.0",
    "emoji-picker-react": "^4.19.1",
    "jose": "^6.0.10",
    "next": "^15.1.0",
    "next-pwa": "^5.6.0",
    "pg": "^8.16.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^22.10.7",
    "@types/pg": "^8.11.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.5.9",
    "prisma": "^6.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.3"
  }
}
