{
  "name": "l2",
  "version": "0.0.1",
  "private": true,
  "description": "",
  "author": "",
  "license": "UNLICENSED",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "ports:free": "node scripts/kill-dev-ports.cjs",
    "sleep:ports": "node -e \"setTimeout(()=>process.exit(0),3000);\"",
    "dev": "npm run ports:free && npm run sleep:ports && node scripts/prep-dev.cjs && concurrently -k -n backend,frontend -c cyan,magenta \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:quick": "npm run ports:free && npm run sleep:ports && npx prisma migrate deploy --schema=database/prisma/schema.prisma && concurrently -k -n backend,frontend -c cyan,magenta \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:check": "node scripts/dev-check.cjs",
    "build": "npm run build -w backend",
    "format": "npm run format -w backend",
    "start": "npm run start -w backend",
    "start:dev": "npm run start:dev -w backend",
    "start:debug": "npm run start:debug -w backend",
    "start:staging": "npm run start:staging -w backend",
    "start:prod": "npm run start:prod -w backend",
    "lint": "npm run lint -w backend",
    "test": "npm run test -w backend",
    "test:watch": "npm run test:watch -w backend",
    "test:cov": "npm run test:cov -w backend",
    "test:debug": "npm run test:debug -w backend",
    "test:e2e": "npm run test:e2e -w backend",
    "dev:backend": "npm run start:dev -w backend",
    "dev:frontend": "npm run dev -w frontend",
    "dev:vm": "npm run ports:free && npm run sleep:ports && node scripts/prep-dev.cjs && concurrently -k -n backend,frontend -c cyan,magenta \"npm run dev:backend\" \"npm run dev:vm -w frontend\"",
    "dev:frontend:webpack": "npm run dev:webpack -w frontend",
    "dev:frontend:clean": "npm run dev:clean -w frontend",
    "dev:frontend:3002": "npm run dev:3002 -w frontend",
    "prisma:generate": "prisma generate --schema=database/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=database/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=database/prisma/schema.prisma",
    "db:up": "docker compose up -d",
    "db:prepare": "npm run db:up && npx prisma migrate deploy --schema=database/prisma/schema.prisma",
    "db:down": "docker compose down",
    "db:seed:admin": "node database/seed-admin.mjs"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "concurrently": "^9.1.2",
    "dotenv": "^16.4.7",
    "kill-port": "^2.0.1",
    "prisma": "^6.0.0"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.19.0",
    "@prisma/client": "^6.19.3"
  }
}
