

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  HOST
  LOCUM
  ADMIN
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

enum VerificationStatus {
  UNVERIFIED
  PENDING_REVIEW
  VERIFIED
  REJECTED
}

enum BillingType {
  FEE_FOR_SERVICE
  SHADOW_BILLING
  BLENDED
}

enum Specialty {
  GENERAL_PRACTICE
  INTERNAL_MEDICINE
  PEDIATRICS
  PSYCHIATRY
  EMERGENCY_MEDICINE
  SURGERY
  OBSTETRICS_GYNECOLOGY
  ANESTHESIOLOGY
  RADIOLOGY
  OTHER
}

enum ShiftType {
  FULL_DAY
  HALF_DAY_AM
  HALF_DAY_PM
  OVERNIGHT
  WEEKEND
}

enum PostingStatus {
  DRAFT
  ACTIVE
  ONGOING
  COMPLETED
  CANCELLED
  EXPIRED
}

enum ApplicationStatus {
  APPLIED
  SHORTLISTED
  CONFIRMED
  REJECTED
  WITHDRAWN
}

enum LocumResponse {
  PENDING
  ACCEPTED
  REJECTED
}

enum DocumentType {
  CPSNS_LICENSE
  CMPA_CERTIFICATE
  DEA_CERTIFICATE
  CV
  PHOTO_ID
  OTHER
}

enum AuditAction {
  CREATE
  READ
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  DOCUMENT_ACCESS
  STATUS_CHANGE
}

model User {
  id                String     @id @default(cuid())
  email             String     @unique
  passwordHash      String
  role              Role
  status            UserStatus @default(PENDING)
  emailVerified     Boolean    @default(false)
  emailVerifiedAt   DateTime?
  lastLoginAt       DateTime?
  hashedRefreshToken String?
  
  lastAppPath       String?
  
  avatarStoragePath String?    @map("avatar_storage_path")
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  locumProfile      LocumProfile?
  hostProfile       HostProfile?
  sentMessages      Message[]         @relation("SentMessages")
  receivedMessages  Message[]         @relation("ReceivedMessages")
  auditLogs         AuditLog[]        @relation("AuditSubject")
  auditActorLogs    AuditLog[]        @relation("AuditActor")
  notifications     NotificationEvent[]

  @@map("users")
}

model LocumProfile {
  id                  String             @id @default(cuid())
  userId              String             @unique
  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  cpsnsId             String             @unique
  msiProviderNumber   String?

  specialty           Specialty
  billingType         BillingType        @default(FEE_FOR_SERVICE)
  summary             String?            @db.Text
  yearsOfExperience   Int?
  ruralExperienced    Boolean            @default(false)
  verificationStatus  VerificationStatus @default(UNVERIFIED)
  verifiedAt          DateTime?
  firstName           String?            @map("first_name")
  lastName            String?            @map("last_name")

  address1            String?
  address2            String?
  postalCode          String?            @map("postal_code")
  city                String?
  province            String?
  specializationText  String?            @map("specialization_text") @db.Text
  licenseFileName     String?            @map("license_file_name")
  licenseOriginalName String?            @map("license_original_name")
  resumeFileName      String?            @map("resume_file_name")
  resumeOriginalName  String?            @map("resume_original_name")
  extraFileName       String?            @map("extra_file_name")
  extraOriginalName   String?            @map("extra_original_name")

  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  documents           Document[]
  applications        Application[]

  @@map("locum_profiles")
}

model HostProfile {
  id                String     @id @default(cuid())
  userId            String     @unique
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  practiceName      String
  address           String
  city              String
  postalCode        String
  province          String     @default("NS")
  ruralDesignation  String?
  servicesOffered   String[]
  highlights        String?    @db.Text
  phone             String?
  website           String?

  contactFirstName     String?
  contactLastName      String?
  cpsnsNumber               String?
  cpsnsVerificationStatus   VerificationStatus @default(UNVERIFIED) @map("cpsns_verification_status")
  cpsnsVerifiedAt           DateTime?          @map("cpsns_verified_at")
  speciality           String?    @db.Text
  licenseFile          String?
  licenseOriginalName  String?    @map("license_original_name")
  address1             String?
  address2             String?
  accommodationProvided Boolean   @default(false)
  practiceType         String?
  numPhysicians        String?
  emr                  String?
  patientVol           String?

  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  postings          JobPosting[]

  @@map("host_profiles")
}

model JobPosting {
  id                String        @id @default(cuid())
  hostProfileId     String
  hostProfile       HostProfile   @relation(fields: [hostProfileId], references: [id], onDelete: Cascade)

  title             String
  description       String        @db.Text
  servicesRequired  String[]
  status            PostingStatus @default(DRAFT)

  dailyRateGP         Decimal       @default(1200.00) @db.Decimal(10, 2)
  dailyRateSpecialist Decimal       @default(1600.00) @db.Decimal(10, 2)

  accommodationProvided Boolean     @default(false)
  travelAllowance       Decimal?    @db.Decimal(10, 2)

  location              String
  isRural               Boolean     @default(false)
  requiredSpecialty     Specialty?

  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  expiresAt             DateTime?

  keyResponsibilities   String[]  @default([]) @map("key_responsibilities")
  startDate             DateTime? @map("start_date") @db.Date
  endDate               DateTime? @map("end_date") @db.Date
  startTime             String?   @map("start_time") @db.VarChar(10)
  endTime               String?   @map("end_time") @db.VarChar(10)
  payPerDay             Decimal?  @map("pay_per_day") @db.Decimal(10, 2)
  minYearsExperience    Int?      @map("min_years_experience")
  maxApplicants         Int       @default(20) @map("max_applicants")
  travelRequired        Boolean   @default(false) @map("travel_required")
  scheduleFlexible      Boolean   @default(false) @map("schedule_flexible")
  requiredCredentials   String[]  @default([]) @map("required_credentials")
  isDeleted             Boolean   @default(false) @map("is_deleted")

  shifts                Shift[]
  applications          Application[]
  messages              Message[]

  @@map("job_postings")
}

model Shift {
  id            String     @id @default(cuid())
  jobPostingId  String
  jobPosting    JobPosting @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)

  date          DateTime   @db.Date
  shiftType     ShiftType  @default(FULL_DAY)
  startTime     DateTime?  @db.Time()
  endTime       DateTime?  @db.Time()
  isFilled      Boolean    @default(false)

  createdAt     DateTime   @default(now())

  @@map("shifts")
}

model Application {
  id              String            @id @default(cuid())
  jobPostingId    String
  jobPosting      JobPosting        @relation(fields: [jobPostingId], references: [id])
  locumProfileId  String
  locumProfile    LocumProfile      @relation(fields: [locumProfileId], references: [id])

  status          ApplicationStatus @default(APPLIED)
  locumResponse   LocumResponse?
  coverNote       String?           @db.Text
  appliedAt       DateTime          @default(now())
  statusChangedAt DateTime          @updatedAt
  locumAcceptedAt DateTime?       @map("locum_accepted_at")

  @@unique([jobPostingId, locumProfileId])
  @@map("applications")
}

model Document {
  id                 String             @id @default(cuid())
  locumProfileId     String
  locumProfile       LocumProfile       @relation(fields: [locumProfileId], references: [id], onDelete: Cascade)

  documentType       DocumentType
  storageUrl         String
  fileName           String
  mimeType           String
  sizeBytes          Int
  verificationStatus VerificationStatus @default(UNVERIFIED)
  expiresAt          DateTime?

  uploadedAt         DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@map("documents")
}

model Message {
  id            String     @id @default(cuid())
  senderId      String
  sender        User       @relation("SentMessages", fields: [senderId], references: [id])
  recipientId   String
  recipient     User       @relation("ReceivedMessages", fields: [recipientId], references: [id])
  jobPostingId  String?
  jobPosting    JobPosting? @relation(fields: [jobPostingId], references: [id])

  body          String     @db.Text
  readAt        DateTime?
  sentAt        DateTime   @default(now())
  
  editedAt   DateTime?  @map("edited_at")
  deletedAt  DateTime?  @map("deleted_at")

  attachments MessageAttachment[]

  @@map("messages")
}

model MessageAttachment {
  id         String   @id @default(cuid())
  messageId  String
  message    Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  
  storagePath String  @map("storage_path")
  fileName    String  @map("file_name")
  mimeType    String  @map("mime_type")
  size        Int

  createdAt  DateTime @default(now())

  @@index([messageId])
  @@map("message_attachments")
}

model NotificationEvent {
  id              String   @id @default(cuid())
  recipientId     String
  recipient       User     @relation(fields: [recipientId], references: [id])

  eventType       String
  referenceId     String?
  referenceType   String?
  payload         Json?
  deliveryStatus  String   @default("PENDING")
  deliveredAt     DateTime?
  sentAt          DateTime @default(now())

  @@map("notification_events")
}

model AuditLog {
  id            String      @id @default(cuid())

  actorId       String?
  actor         User?       @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  adminActorId  String?
  adminActor    Admin?      @relation(fields: [adminActorId], references: [id], onDelete: SetNull)

  subjectId     String?
  subject       User?       @relation("AuditSubject", fields: [subjectId], references: [id], onDelete: SetNull)

  action        AuditAction
  entity        String
  entityId      String?

  before        Json?
  after         Json?

  ipAddress     String?
  userAgent     String?
  endpoint      String?

  createdAt     DateTime    @default(now())

  @@index([actorId])
  @@index([adminActorId])
  @@index([subjectId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
model Otp {
  id        String   @id @default(cuid())
  email     String
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@map("otps")
}

// Separate table for Admin authentication/authorization.
// Do NOT mix admin accounts with the main User table.
model Admin {
  id        String     @id @default(cuid())
  name      String
  email     String     @unique
  role      String     @default("admin")
  createdAt DateTime   @default(now())
  auditLogs AuditLog[]

  @@map("admins")
}