// prisma/schema.prisma
// LocumConnect – Full Schema (Section 11.3 + Section 13 PIPEDA)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  HOST
  LOCUM
  ADMIN
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

enum VerificationStatus {
  UNVERIFIED
  PENDING_REVIEW
  VERIFIED
  REJECTED
}

enum BillingType {
  FEE_FOR_SERVICE
  SHADOW_BILLING
  BLENDED
}

enum Specialty {
  GENERAL_PRACTICE
  INTERNAL_MEDICINE
  PEDIATRICS
  PSYCHIATRY
  EMERGENCY_MEDICINE
  SURGERY
  OBSTETRICS_GYNECOLOGY
  ANESTHESIOLOGY
  RADIOLOGY
  OTHER
}

enum ShiftType {
  FULL_DAY
  HALF_DAY_AM
  HALF_DAY_PM
  OVERNIGHT
  WEEKEND
}

enum PostingStatus {
  DRAFT
  ACTIVE
  FILLED
  CANCELLED
  EXPIRED
}

enum ApplicationStatus {
  APPLIED
  SHORTLISTED
  CONFIRMED
  REJECTED
  WITHDRAWN
}

enum DocumentType {
  CPSNS_LICENSE
  CMPA_CERTIFICATE
  DEA_CERTIFICATE
  CV
  PHOTO_ID
  OTHER
}

enum AuditAction {
  CREATE
  READ
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  DOCUMENT_ACCESS
  STATUS_CHANGE
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────

model User {
  id                String     @id @default(cuid())
  email             String     @unique
  passwordHash      String
  role              Role
  status            UserStatus @default(PENDING)
  emailVerified     Boolean    @default(false)
  emailVerifiedAt   DateTime?
  lastLoginAt       DateTime?
  hashedRefreshToken String?
  /** Last in-app path for resume-after-login (server-side). */
  lastAppPath       String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  // Relations
  locumProfile      LocumProfile?
  hostProfile       HostProfile?
  sentMessages      Message[]         @relation("SentMessages")
  receivedMessages  Message[]         @relation("ReceivedMessages")
  auditLogs         AuditLog[]        @relation("AuditSubject")
  auditActorLogs    AuditLog[]        @relation("AuditActor")
  notifications     NotificationEvent[]

  @@map("users")
}

// ─────────────────────────────────────────────
// LOCUM PROFILE
// ─────────────────────────────────────────────

model LocumProfile {
  id                  String             @id @default(cuid())
  userId              String             @unique
  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Nova Scotia specific identifiers
  cpsnsId             String             @unique          // College of Physicians and Surgeons of NS
  msiProviderNumber   String?                             // Medical Services Insurance (struck-through in PRD = optional)

  specialty           Specialty
  billingType         BillingType        @default(FEE_FOR_SERVICE)
  summary             String?            @db.Text
  yearsOfExperience   Int?
  ruralExperienced    Boolean            @default(false)
  verificationStatus  VerificationStatus @default(UNVERIFIED)
  verifiedAt          DateTime?

  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  // Relations
  documents           Document[]
  applications        Application[]

  @@map("locum_profiles")
}

// ─────────────────────────────────────────────
// HOST / CLINIC PROFILE
// ─────────────────────────────────────────────

model HostProfile {
  id                String     @id @default(cuid())
  userId            String     @unique
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  practiceName      String
  address           String
  city              String
  postalCode        String
  province          String     @default("NS")
  ruralDesignation  String?    // e.g. "Zone 1", "RCCBC Tier 3"
  servicesOffered   String[]   // array of service strings
  highlights        String?    @db.Text
  phone             String?
  website           String?

  // Extended fields (host setup + profile UI; also used by Next.js /api/host/profile)
  contactFirstName     String?
  contactLastName      String?
  cpsnsNumber          String?
  speciality           String?    @db.Text
  licenseFile          String?
  address1             String?
  address2             String?
  accommodationProvided Boolean   @default(false)
  practiceType         String?
  numPhysicians        String?
  emr                  String?
  patientVol           String?

  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  // Relations
  postings          JobPosting[]

  @@map("host_profiles")
}

// ─────────────────────────────────────────────
// JOB POSTING
// ─────────────────────────────────────────────

model JobPosting {
  id                String        @id @default(cuid())
  hostProfileId     String
  hostProfile       HostProfile   @relation(fields: [hostProfileId], references: [id], onDelete: Cascade)

  title             String
  description       String        @db.Text
  servicesRequired  String[]
  status            PostingStatus @default(DRAFT)

  // Nova Scotia standardised rates (CAD / day)
  // GP: $1,200 | Specialist: $1,600
  dailyRateGP         Decimal       @default(1200.00) @db.Decimal(10, 2)
  dailyRateSpecialist Decimal       @default(1600.00) @db.Decimal(10, 2)

  // Accommodation & travel
  accommodationProvided Boolean     @default(false)
  travelAllowance       Decimal?    @db.Decimal(10, 2)

  location              String
  isRural               Boolean     @default(false)
  requiredSpecialty     Specialty?

  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  expiresAt             DateTime?

  // Relations
  shifts                Shift[]
  applications          Application[]
  messages              Message[]

  @@map("job_postings")
}

// ─────────────────────────────────────────────
// SHIFT (date slots attached to a posting)
// ─────────────────────────────────────────────

model Shift {
  id            String     @id @default(cuid())
  jobPostingId  String
  jobPosting    JobPosting @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)

  date          DateTime   @db.Date
  shiftType     ShiftType  @default(FULL_DAY)
  startTime     DateTime?  @db.Time()
  endTime       DateTime?  @db.Time()
  isFilled      Boolean    @default(false)

  createdAt     DateTime   @default(now())

  @@map("shifts")
}

// ─────────────────────────────────────────────
// APPLICATION
// ─────────────────────────────────────────────

model Application {
  id              String            @id @default(cuid())
  jobPostingId    String
  jobPosting      JobPosting        @relation(fields: [jobPostingId], references: [id])
  locumProfileId  String
  locumProfile    LocumProfile      @relation(fields: [locumProfileId], references: [id])

  status          ApplicationStatus @default(APPLIED)
  coverNote       String?           @db.Text
  appliedAt       DateTime          @default(now())
  statusChangedAt DateTime          @updatedAt

  @@unique([jobPostingId, locumProfileId])
  @@map("applications")
}

// ─────────────────────────────────────────────
// DOCUMENT (license uploads via Cloudinary/GCS)
// ─────────────────────────────────────────────

model Document {
  id                 String             @id @default(cuid())
  locumProfileId     String
  locumProfile       LocumProfile       @relation(fields: [locumProfileId], references: [id], onDelete: Cascade)

  documentType       DocumentType
  storageUrl         String             // GCS signed-path or Cloudinary public_id
  fileName           String
  mimeType           String
  sizeBytes          Int
  verificationStatus VerificationStatus @default(UNVERIFIED)
  expiresAt          DateTime?          // license expiry date

  uploadedAt         DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@map("documents")
}

// ─────────────────────────────────────────────
// MESSAGE
// ─────────────────────────────────────────────

model Message {
  id            String     @id @default(cuid())
  senderId      String
  sender        User       @relation("SentMessages", fields: [senderId], references: [id])
  recipientId   String
  recipient     User       @relation("ReceivedMessages", fields: [recipientId], references: [id])
  jobPostingId  String?
  jobPosting    JobPosting? @relation(fields: [jobPostingId], references: [id])

  body          String     @db.Text
  readAt        DateTime?
  sentAt        DateTime   @default(now())

  @@map("messages")
}

// ─────────────────────────────────────────────
// NOTIFICATION EVENT
// ─────────────────────────────────────────────

model NotificationEvent {
  id              String   @id @default(cuid())
  recipientId     String
  recipient       User     @relation(fields: [recipientId], references: [id])

  eventType       String   // e.g. "APPLICATION_RECEIVED", "STATUS_CHANGED"
  referenceId     String?  // Application or Posting ID
  referenceType   String?  // "Application" | "JobPosting"
  payload         Json?
  deliveryStatus  String   @default("PENDING")
  deliveredAt     DateTime?
  sentAt          DateTime @default(now())

  @@map("notification_events")
}

// ─────────────────────────────────────────────
// AUDIT LOG  –  PIPEDA / Section 13 Compliance
// ─────────────────────────────────────────────
// Captures every sensitive action for regulatory audit trail.
// Immutable by design: no updatedAt, no cascade deletes.

model AuditLog {
  id            String      @id @default(cuid())

  // Who performed the action
  actorId       String?
  actor         User?       @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  // Who / what was affected
  subjectId     String?
  subject       User?       @relation("AuditSubject", fields: [subjectId], references: [id], onDelete: SetNull)

  action        AuditAction
  entity        String      // Table/model name, e.g. "Document", "Application"
  entityId      String?     // PK of the affected record

  // Full before/after snapshot for data-change events
  before        Json?
  after         Json?

  // Request metadata (PIPEDA requires IP logging)
  ipAddress     String?
  userAgent     String?
  endpoint      String?

  createdAt     DateTime    @default(now())

  @@index([actorId])
  @@index([subjectId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
model Otp {
  id        String   @id @default(cuid())
  email     String
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@map("otps")
}