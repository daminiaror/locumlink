generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  HOST
  LOCUM
  ADMIN
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

enum VerificationStatus {
  UNVERIFIED
  PENDING_REVIEW
  VERIFIED
  REJECTED
}

enum BillingType {
  FEE_FOR_SERVICE
  SHADOW_BILLING
  BLENDED
}

enum Specialty {
  GENERAL_PRACTICE
  INTERNAL_MEDICINE
  PEDIATRICS
  PSYCHIATRY
  EMERGENCY_MEDICINE
  SURGERY
  OBSTETRICS_GYNECOLOGY
  ANESTHESIOLOGY
  RADIOLOGY
  OTHER
}

enum ShiftType {
  FULL_DAY
  HALF_DAY_AM
  HALF_DAY_PM
  OVERNIGHT
  WEEKEND
}

enum PostingStatus {
  DRAFT
  ACTIVE
  ONGOING
  COMPLETED
  CANCELLED
  EXPIRED
}

enum ApplicationStatus {
  APPLIED
  SHORTLISTED
  CONFIRMED
  REJECTED
  WITHDRAWN
}

enum LocumResponse {
  PENDING
  ACCEPTED
  REJECTED
}

enum DocumentType {
  CPSNS_LICENSE
  CMPA_CERTIFICATE
  DEA_CERTIFICATE
  CV
  PHOTO_ID
  REFERENCE_LETTER
  OTHER
}

enum AuditAction {
  CREATE
  READ
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  DOCUMENT_ACCESS
  STATUS_CHANGE
}

model User {
  id                 String     @id @default(cuid())
  email              String     @unique
  passwordHash       String
  role               Role
  status             UserStatus @default(PENDING)
  emailVerified      Boolean    @default(false)
  emailVerifiedAt    DateTime?
  lastLoginAt        DateTime?
  hashedRefreshToken String?
  lastAppPath        String?
  avatarStoragePath  String?    @map("avatar_storage_path")

  // PIPEDA consent (L2-E6.4)
  consentGivenAt     DateTime?  @map("consent_given_at")
  consentVersion     String?    @map("consent_version")

  // Suspension fields (L2-E7.4)
  suspensionNote     String?    @map("suspension_note")
  suspendedAt        DateTime?  @map("suspended_at")
  deactivatedAt      DateTime?  @map("deactivated_at")

  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  locumProfile       LocumProfile?
  hostProfile        HostProfile?
  sentMessages       Message[]          @relation("SentMessages")
  receivedMessages   Message[]          @relation("ReceivedMessages")
  auditLogs          AuditLog[]         @relation("AuditSubject")
  auditActorLogs     AuditLog[]         @relation("AuditActor")
  notifications      NotificationEvent[]
  pushSubscriptions  PushSubscription[]

  @@map("users")
}

model LocumProfile {
  id                  String             @id @default(cuid())
  userId              String             @unique
  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  cpsnsId             String             @unique
  msiProviderNumber   String?

  specialty           Specialty
  billingType         BillingType        @default(FEE_FOR_SERVICE)
  summary             String?            @db.Text
  yearsOfExperience   Int?
  ruralExperienced    Boolean            @default(false)
  cpsnsVerificationStatus VerificationStatus @default(UNVERIFIED) @map("cpsns_verification_status")
  cpsnsVerifiedAt         DateTime?          @map("cpsns_verified_at")
  credentialSubmittedAt   DateTime?          @map("credential_submitted_at")

  // Rejection fields (L2-E7.3 / AD-02)
  rejectionReason     String?            @map("rejection_reason") @db.Text
  rejectedAt          DateTime?          @map("rejected_at")

  firstName           String?            @map("first_name")
  lastName            String?            @map("last_name")
  address1            String?
  address2            String?
  postalCode          String?            @map("postal_code")
  city                String?
  province            String?
  phone               String?
  specializationText  String?            @map("specialization_text") @db.Text
  licenseFileName     String?            @map("license_file_name")
  licenseOriginalName String?            @map("license_original_name")
  resumeFileName      String?            @map("resume_file_name")
  resumeOriginalName  String?            @map("resume_original_name")
  extraFileName       String?            @map("extra_file_name")
  extraOriginalName   String?            @map("extra_original_name")

  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  documents           Document[]
  applications        Application[]

  @@map("locum_profiles")
}

model HostProfile {
  id                      String             @id @default(cuid())
  userId                  String             @unique
  user                    User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  practiceName            String
  address                 String
  city                    String
  postalCode              String
  province                String             @default("NS")
  ruralDesignation        String?
  servicesOffered         String[]
  highlights              String?            @db.Text
  phone                   String?
  website                 String?

  contactFirstName        String?
  contactLastName         String?
  cpsnsNumber             String?
  cpsnsVerificationStatus VerificationStatus @default(UNVERIFIED) @map("cpsns_verification_status")
  cpsnsVerifiedAt         DateTime?          @map("cpsns_verified_at")
  credentialSubmittedAt   DateTime?          @map("credential_submitted_at")
  rejectionReason         String?            @map("rejection_reason") @db.Text
  rejectedAt              DateTime?          @map("rejected_at")
  speciality              String?            @db.Text
  licenseFile             String?
  licenseOriginalName     String?            @map("license_original_name")

  // Photo ID upload (PRD 9.1 comment AT42)
  photoIdFile             String?            @map("photo_id_file")
  photoIdOriginalName     String?            @map("photo_id_original_name")

  address1                String?
  address2                String?
  accommodationProvided   Boolean            @default(false)
  practiceType            String?
  numPhysicians           String?
  emr                     String?
  patientVol              String?

  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt

  postings                JobPosting[]

  @@map("host_profiles")
}

model JobPosting {
  id                  String        @id @default(cuid())
  hostProfileId       String
  hostProfile         HostProfile   @relation(fields: [hostProfileId], references: [id], onDelete: Cascade)

  title               String
  description         String        @db.Text
  servicesRequired    String[]
  status              PostingStatus @default(DRAFT)

  // PRD Section 2.2 required fields
  leaveType           String?       @map("leave_type")
  fullHalfDay         String?       @map("full_half_day")

  dailyRateGP         Decimal       @default(1200.00) @db.Decimal(10, 2)
  dailyRateSpecialist Decimal       @default(1600.00) @db.Decimal(10, 2)

  accommodationProvided Boolean     @default(false)
  travelAllowance       Decimal?    @db.Decimal(10, 2)

  location              String
  isRural               Boolean     @default(false)
  requiredSpecialty     Specialty?

  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  expiresAt             DateTime?

  keyResponsibilities   String[]    @default([]) @map("key_responsibilities")
  startDate             DateTime?   @map("start_date") @db.Date
  endDate               DateTime?   @map("end_date") @db.Date
  startTime             String?     @map("start_time") @db.VarChar(10)
  endTime               String?     @map("end_time") @db.VarChar(10)
  payPerDay             Decimal?    @map("pay_per_day") @db.Decimal(10, 2)
  minYearsExperience    Int?        @map("min_years_experience")
  maxApplicants         Int         @default(20) @map("max_applicants")
  travelRequired        Boolean     @default(false) @map("travel_required")
  scheduleFlexible      Boolean     @default(false) @map("schedule_flexible")
  requiredCredentials   String[]    @default([]) @map("required_credentials")
  isDeleted             Boolean     @default(false) @map("is_deleted")

  shifts                Shift[]
  applications          Application[]
  messages              Message[]

  @@index([status, id], map: "job_postings_status_id_idx")
  @@map("job_postings")
}

model Shift {
  id           String     @id @default(cuid())
  jobPostingId String
  jobPosting   JobPosting @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)

  date         DateTime   @db.Date
  shiftType    ShiftType  @default(FULL_DAY)
  startTime    DateTime?  @db.Time()
  endTime      DateTime?  @db.Time()
  isFilled     Boolean    @default(false)

  createdAt    DateTime   @default(now())

  @@map("shifts")
}

model Application {
  id              String            @id @default(cuid())
  jobPostingId    String
  jobPosting      JobPosting        @relation(fields: [jobPostingId], references: [id])
  locumProfileId  String
  locumProfile    LocumProfile      @relation(fields: [locumProfileId], references: [id])

  status          ApplicationStatus @default(APPLIED)
  locumResponse   LocumResponse?
  coverNote       String?           @db.Text
  appliedAt       DateTime          @default(now())
  statusChangedAt DateTime          @updatedAt
  locumAcceptedAt DateTime?         @map("locum_accepted_at")

  // Placement timestamp for fill rate + avg time-to-placement (L2-E7.1)
  placedAt        DateTime?         @map("placed_at")

  @@unique([jobPostingId, locumProfileId])
  @@index([jobPostingId, id], map: "applications_job_posting_id_id_idx")
  @@index([locumProfileId, id], map: "applications_locum_profile_id_id_idx")
  @@map("applications")
}

model Document {
  id                 String             @id @default(cuid())
  locumProfileId     String
  locumProfile       LocumProfile       @relation(fields: [locumProfileId], references: [id], onDelete: Cascade)

  documentType       DocumentType
  storageUrl         String
  fileName           String
  mimeType           String
  sizeBytes          Int
  verificationStatus VerificationStatus @default(UNVERIFIED)
  expiresAt          DateTime?

  uploadedAt         DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@map("documents")
}

model Message {
  id           String      @id @default(cuid())
  senderId     String
  sender       User        @relation("SentMessages", fields: [senderId], references: [id])
  recipientId  String
  recipient    User        @relation("ReceivedMessages", fields: [recipientId], references: [id])
  jobPostingId String?
  jobPosting   JobPosting? @relation(fields: [jobPostingId], references: [id])

  body         String      @db.Text
  readAt       DateTime?
  sentAt       DateTime    @default(now())
  editedAt     DateTime?   @map("edited_at")
  deletedAt    DateTime?   @map("deleted_at")

  attachments  MessageAttachment[]

  @@index([senderId, recipientId, id], map: "messages_sender_recipient_id_idx")
  @@map("messages")
}

model MessageAttachment {
  id          String   @id @default(cuid())
  messageId   String
  message     Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  storagePath String   @map("storage_path")
  fileName    String   @map("file_name")
  mimeType    String   @map("mime_type")
  size        Int

  createdAt   DateTime @default(now())

  @@index([messageId])
  @@map("message_attachments")
}

model NotificationEvent {
  id             String    @id @default(cuid())
  recipientId    String
  recipient      User      @relation(fields: [recipientId], references: [id])

  eventType      String
  referenceId    String?
  referenceType  String?
  payload        Json?
  deliveryStatus String    @default("PENDING")
  deliveredAt    DateTime?
  sentAt         DateTime  @default(now())

  @@index([recipientId, id], map: "notification_events_recipient_id_idx")
  @@map("notification_events")
}

model AuditLog {
  id           String      @id @default(cuid())

  actorId      String?
  actor        User?       @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  adminActorId String?
  adminActor   Admin?      @relation(fields: [adminActorId], references: [id], onDelete: SetNull)

  subjectId    String?
  subject      User?       @relation("AuditSubject", fields: [subjectId], references: [id], onDelete: SetNull)

  action       AuditAction
  entity       String
  entityId     String?

  // PRD Section 11.3 required fields
  outcome      String      @default("SUCCESS")
  actorRole    String?     @map("actor_role")

  before       Json?
  after        Json?

  ipAddress    String?
  userAgent    String?
  endpoint     String?

  createdAt    DateTime    @default(now())

  @@index([actorId])
  @@index([adminActorId])
  @@index([subjectId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model EmailLog {
  id                String    @id @default(cuid())
  recipient         String
  eventType         String    @map("event_type")
  status            String    @default("PENDING")
  provider          String    @default("zeptomail")
  providerMessageId String?   @map("provider_message_id")
  error             String?
  referenceId       String?   @map("reference_id")
  referenceType     String?   @map("reference_type")
  sentAt            DateTime  @default(now()) @map("sent_at")
  deliveredAt       DateTime? @map("delivered_at")

  @@index([recipient])
  @@index([sentAt])
  @@index([eventType])
  @@map("email_logs")
}

model Otp {
  id        String   @id @default(cuid())
  email     String
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@map("otps")
}

// Separate table for Admin authentication/authorization.
// Do NOT mix admin accounts with the main User table.
model Admin {
  id            String                   @id @default(cuid())
  name          String
  email         String                   @unique
  role          String                   @default("admin")
  createdAt     DateTime                 @default(now())
  auditLogs     AuditLog[]
  notifications AdminNotificationEvent[]

  @@map("admins")
}

model AdminNotificationEvent {
  id             String    @id @default(cuid())
  adminId        String    @map("admin_id")
  admin          Admin     @relation(fields: [adminId], references: [id], onDelete: Cascade)

  eventType      String    @map("event_type")
  referenceId    String?   @map("reference_id")
  referenceType  String?   @map("reference_type")
  payload        Json?
  deliveryStatus String    @default("DELIVERED") @map("delivery_status")
  deliveredAt    DateTime? @map("delivered_at")
  sentAt         DateTime  @default(now()) @map("sent_at")

  @@index([adminId])
  @@map("admin_notification_events")
}
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("push_subscriptions")
}
